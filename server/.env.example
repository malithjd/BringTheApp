# ========================================================
# BringTheApp – Server Environment Variables
# ========================================================
# Copy this file to .env and fill in your keys.

# ---- Vision Provider (document scanning) ----
# Which AI to use for document extraction: gemini | claude | openai
# Default: gemini (free tier, no credit card needed)
VISION_PROVIDER=gemini

# Google Gemini (FREE – default)
# Get your key: https://aistudio.google.com/apikey
GOOGLE_AI_KEY=your_google_ai_key
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (paid – premium tier)
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI GPT-4o (paid – premium tier)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# ---- Other APIs ----
# NHTSA vPIC – FREE, no key needed (VIN decoding)
# OCR.space – legacy fallback only
OCR_SPACE_KEY=your_key

# ---- Server ----
PORT=3001
NODE_ENV=development
