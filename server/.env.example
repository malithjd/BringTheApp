# ========================================================
# BringTheApp – Server Environment Variables
# ========================================================
# Copy this file to .env and fill in your keys.

# ---- Vision Provider (document scanning) ----
# Which AI to use for document extraction: gemini | claude | openai
# Default: gemini (free tier, no credit card needed)
VISION_PROVIDER=gemini

# Google Gemini (FREE – default)
# Get your key: https://aistudio.google.com/apikey
GOOGLE_AI_KEY=your_google_ai_key
GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude (paid – premium tier)
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI GPT-4o (paid – premium tier)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# ---- Market Data (Auto.dev) ----
# Free tier: 1,000 calls/month, VIN decode + listings + photos
# Get your key: https://www.auto.dev (sign up for Starter plan)
AUTO_DEV_API_KEY=your_auto_dev_api_key

# ---- Feature Flags ----
# Set to "false" to disable Auto.dev features (listings, photos, market avg)
PAID_FEATURES=true

# ---- Supabase (auth + saved reports) ----
# URL + anon key are shared with the client (VITE_ prefix). The service-role
# key is server-only — it verifies bearer tokens and performs admin actions.
# NEVER expose SUPABASE_SERVICE_ROLE_KEY to the client.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- Email report (Resend) ----
# Used to email the PDF deal report. Get a key: https://resend.com/api-keys
# EMAIL_FROM must be a verified sender/domain in your Resend account.
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=BringTheApp <reports@yourdomain.com>

# ---- Other APIs ----
# NHTSA vPIC – FREE, no key needed (VIN decoding)
# OCR.space – legacy fallback only
OCR_SPACE_KEY=your_key

# ---- Server ----
PORT=3001
NODE_ENV=development
